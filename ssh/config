# SSH Config
# To Add to the macOS Keychain
# $ ssh-add ~/.ssh/id_ed25519_ONM_MBP2025
# Edited: Apr 19, 2026

# GLOBAL DEFAULTS
Host *
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes
  ServerAliveInterval 60
  ServerAliveCountMax 3
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

# Brajeshwar
Host github-brajeshwar
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_ONM_MBP2025
  IdentitiesOnly yes

# Work
Host github-work
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_work
  IdentitiesOnly yes

# Laaija
Host github-laaija
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_laaija
  IdentitiesOnly yes

# Wipro
Host github-wipro
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_wipro
  IdentitiesOnly yes

Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
