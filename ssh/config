# SSH Config
# Edited: May 16, 2026
#
# Personal device-specific keys live in ~/.ssh/config.local (not committed).
# See ssh/config.local.example for the pattern.

# GLOBAL DEFAULTS
Host *
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes
  ServerAliveInterval 60
  ServerAliveCountMax 3
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

# Device-specific and personal identities — kept off the public repo.
# Copy ssh/config.local.example to ~/.ssh/config.local and fill in.
Include ~/.ssh/config.local

# Work
Host github-work
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_work
  IdentitiesOnly yes

# Job 94776
Host github-job94776
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_job94776
  IdentitiesOnly yes

# Optional: route all SSH auth through Bitwarden's SSH agent.
# Enable in Bitwarden desktop: Settings → SSH Agent → Enable SSH Agent
# This lets Bitwarden unlock and serve your SSH keys, replacing ssh-add prompts.
# Recommended over 1Password for teams — open source, self-hostable, cross-platform.
#
# Host *
#   IdentityAgent ~/.bitwarden-ssh-agent.sock
