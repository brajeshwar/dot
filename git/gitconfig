[user]
    name = Brajeshwar Oinam
    email = brajeshwar@oinam.com
    signingkey = 47EE96D63DFDA9372079337A9C9CD08302E7C29F

[gpg]
    program = gpg

[commit]
    gpgsign = true

[tag]
    gpgSign = true

[credential]
    helper = osxkeychain

[core]
    editor = vim
    excludesfile = ~/.gitignore_global
    whitespace = space-before-tab,indent-with-non-tab,trailing-space
    autocrlf = false

[grep]
    lineNumber = true

# pushInsteadOf lives in ~/.gitconfig.local, not here.
# Personal machines: add [url "git@github.com:"] pushInsteadOf = https://github.com/
# Office/SSH-blocked machines: omit it entirely and use HTTPS throughout.

[alias]
    amend = !git add -A && git commit --amend --no-edit
    c     = !git add -A && git commit -m
    caa   = commit -a --amend -C HEAD
    co    = checkout
    fo    = fetch origin --prune
    lg    = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(blue)<%an>%Creset' --abbrev-commit
    pullm = pull --rebase origin main
    pushm = push origin main
    s     = status -sb
    undo  = reset --soft HEAD^

[color]
    ui = true

[merge]
    stat = true
    log = true

[mergetool]
    keepBackup = true
    prompt = false

[init]
    defaultBranch = main

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[credential "https://gist.github.com"]

# SSH signature verification (only consulted when verifying SSH-signed
# commits/tags). Placed before the includes so ~/.gitconfig.local can
# override it per-device. Path is tilde-expanded by git.
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers

# Machine-level overrides: SSH vs HTTPS, signing key, credential helpers.
# Copy git/gitconfig.local.example → ~/.gitconfig.local (never committed).
[include]
    path = ~/.gitconfig.local

# Work-repo overrides: identity and credentials for work GitHub account.
# Copy git/gitconfig.work.example → ~/.gitconfig.work (never committed).
# Applied to any repo cloned under ~/dev/.
[includeIf "gitdir:~/dev/"]
    path = ~/.gitconfig.work