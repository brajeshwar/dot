# Git Config
# Edited: Mar 15, 2026

[user]
    name = Brajeshwar Oinam
    email = brajeshwar@oinam.com
    signingkey = 47EE96D63DFDA9372079337A9C9CD08302E7C29F

[gpg]
    program = gpg

[commit]
    gpgsign = true

[tag]
    gpgSign = true

[credential]
    helper = osxkeychain

[core]
    editor = vim
    excludesfile = ~/.gitignore_global
    whitespace = space-before-tab,indent-with-non-tab,trailing-space
    autocrlf = false

[grep]
    lineNumber = true

[url "git@github.com:"]
    pushInsteadOf = https://github.com/

[alias]
    amend = !git add -A && git commit --amend --no-edit
    c     = !git add -A && git commit -m
    caa   = commit -a --amend -C HEAD
    co    = checkout
    fo    = fetch origin --prune
    lg    = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(blue)<%an>%Creset' --abbrev-commit
    pullm = pull --rebase origin main
    pushm = push origin main
    s     = status -sb
    undo  = reset --soft HEAD^

[color]
    ui = true

[merge]
    stat = true
    log = true

[mergetool]
    keepBackup = true
    prompt = false

[init]
    defaultBranch = main

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

# SSH signature verification (only consulted when verifying SSH-signed
# commits/tags). Placed before the includes so ~/.gitconfig.local can
# override it per-device. Path is tilde-expanded by git.
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers

# Local identity overrides (work email, work GPG key, etc.)
# Copy git/gitconfig.local.example to ~/.gitconfig.local and fill in.
# Applied globally; also auto-applied to any repo under ~/work/.
[include]
    path = ~/.gitconfig.local
[includeIf "gitdir:~/work/"]
    path = ~/.gitconfig.local