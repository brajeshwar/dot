# git/gitconfig.local.example
#
# Copy this to ~/.gitconfig.local (never committed).
# Overrides identity and signing for work or device-specific contexts.
# Referenced via [include] and [includeIf] in git/gitconfig.

[user]
    name  = Your Name
    email = you@work.com
    # For SSH signing (recommended for work machines — no GPG setup needed):
    signingkey = ~/.ssh/id_ed25519_job94776.pub
    # For GPG signing (personal machines):
    # signingkey = YOUR_GPG_KEY_FINGERPRINT

# SSH signing — comment this block out if using GPG instead
[gpg]
    format = ssh

[gpg "ssh"]
    # GitHub: add the same key under Settings → SSH keys → Signing keys
    allowedSignersFile = ~/.ssh/allowed_signers

# Uncomment to pin a specific SSH key for git push on this machine
# [core]
#     sshCommand = ssh -i ~/.ssh/id_ed25519_job94776
