# ---------------------------------
# Prompt (clean, simple, minimal)
# Late Update: Mar 15, 2026
# ---------------------------------
PROMPT='%F{red}%~ %F{yellow}› %f'

# ---------------------------------
# GPG (interactive only)
# ---------------------------------
export GPG_TTY=$(tty)
gpgconf --launch gpg-agent

# ---------------------------------
# rbenv (interactive only)
# ---------------------------------
if command -v rbenv >/dev/null; then
  eval "$(rbenv init - zsh)"
fi

# ---------------------------------
# Shell behavior
# ---------------------------------
setopt autocd
setopt correct
setopt hist_ignore_dups

HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history

# ---------------------------------
# OpenClaw completion
# ---------------------------------
[ -f "$HOME/.openclaw-dench/completions/openclaw.zsh" ] && source "$HOME/.openclaw-dench/completions/openclaw.zsh"
