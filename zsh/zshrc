# ---------------------------------
# Prompt (clean, simple, minimal)
# Edited: Mar 15, 2026
# ---------------------------------
PROMPT='%F{red}%~ %F{yellow}› %f'

# ---------------------------------
# GPG (interactive only)
# ---------------------------------
export GPG_TTY=$(tty)
gpgconf --launch gpg-agent

# ---------------------------------
# rbenv (interactive only)
# ---------------------------------
if command -v rbenv >/dev/null; then
  eval "$(rbenv init - zsh)"
fi

# ---------------------------------
# Shell behavior
# ---------------------------------
setopt autocd
setopt correct
setopt hist_ignore_dups

HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history

# ---------------------------------
# Completion system
# ---------------------------------
autoload -Uz compinit && compinit

# ---------------------------------
# Window title — show project path, not the running command
# (Ghostty's shell-integration title feature is disabled in ghostty/config)
# ---------------------------------
autoload -Uz add-zsh-hook
_set_window_title() { print -Pn "\e]2;%~\a" }
add-zsh-hook precmd _set_window_title
add-zsh-hook chpwd _set_window_title

# Stop Claude Code from overriding the terminal title with "Claude Code".
# Undocumented env var — remove if it stops working in a future release.
export CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1

# ---------------------------------
# Local overrides (machine/work-specific — not committed)
# ---------------------------------
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# >>> grok installer >>>
export PATH="$HOME/.grok/bin:$PATH"
fpath=(~/.grok/completions/zsh $fpath)
autoload -Uz compinit && compinit -C
# <<< grok installer <<<

# >>> open-knowledge cli >>>
# ! Contents within this block are managed by Open Knowledge. Do not edit.
# ! Delete this whole block to opt out — Open Knowledge will not re-add it.
[ -f "$HOME/.ok/env.sh" ] && . "$HOME/.ok/env.sh"
# <<< open-knowledge cli <<<


# Hermes Agent — ensure ~/.local/bin is on PATH
export PATH="$HOME/.local/bin:$PATH"
